generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum UserRole {
  STUDENT
  MENTOR
  ADMIN
}

enum RequestStatus {
  PENDING
  ACCEPTED
  REJECTED
  COMPLETED
  CANCELLED
}

enum SessionStatus {
  SCHEDULED
  COMPLETED
  NO_SHOW
  CANCELLED
}

enum VerifiedStatus {
  PENDING
  VERIFIED
  REJECTED
}

enum AvailabilityStatus {
  AVAILABLE
  BUSY
  UNAVAILABLE
}

model User {
  id             String             @id @default(uuid())
  email          String             @unique
  password       String
  name           String
  role           UserRole           @default(STUDENT)
  verifiedStatus VerifiedStatus     @default(PENDING)
  domainTags     String[]
  availability   AvailabilityStatus @default(AVAILABLE)
  createdAt      DateTime           @default(now())
  updatedAt      DateTime           @updatedAt

  mentorProfile    MentorProfile?
  studentProfile   StudentProfile?
  sentRequests     MentorRequest[]   @relation("StudentRequests")
  receivedRequests MentorRequest[]  @relation("MentorRequests")
  reviews          Review[]          @relation("ReviewAuthor")
  receivedReviews  Review[]          @relation("ReviewTarget")
  institutionId    String?
  institution      Institution?      @relation(fields: [institutionId], references: [id])
  employments      Employment[]
  circleMemberships CircleMembership[]
  createdCircles   Circle[]         @relation("CircleCreator")
  impactScores     ImpactScore[]
}

model Institution {
  id        String   @id @default(uuid())
  name      String
  type      String?  // e.g. UNIVERSITY, COLLEGE, SCHOOL
  website   String?
  location  String?
  users     User[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Employer {
  id          String       @id @default(uuid())
  name        String
  industry    String?
  website     String?
  employments Employment[]
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
}

model Employment {
  id         String   @id @default(uuid())
  userId     String
  user       User     @relation(fields: [userId], references: [id])
  employerId String
  employer   Employer @relation(fields: [employerId], references: [id])
  title      String?
  startDate  DateTime?
  endDate    DateTime?
  isCurrent  Boolean  @default(false)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@unique([userId, employerId])
}

model Circle {
  id          String           @id @default(uuid())
  name        String
  description String?
  creatorId   String
  creator     User             @relation("CircleCreator", fields: [creatorId], references: [id])
  memberships CircleMembership[]
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
}

model CircleMembership {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  circleId  String
  circle    Circle   @relation(fields: [circleId], references: [id])
  role      String?  // e.g. ADMIN, MEMBER
  joinedAt  DateTime @default(now())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, circleId])
}

model ImpactScore {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  score     Float
  category  String?  // e.g. MENTORING, LEARNING, COMMUNITY
  period    String?  // e.g. MONTHLY, QUARTERLY
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model MentorProfile {
  id              String   @id @default(uuid())
  userId          String   @unique
  user            User     @relation(fields: [userId], references: [id])
  bio             String?
  expertise       String[]
  experienceYears Int      @default(0)
  hourlyRate      Float?
  isAvailable     Boolean  @default(true)
  reputationScore Float    @default(0)
  totalSessions   Int      @default(0)
  successRate     Float    @default(0)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model StudentProfile {
  id             String   @id @default(uuid())
  userId         String   @unique
  user           User     @relation(fields: [userId], references: [id])
  goal           String?
  currentLevel   String?
  targetField    String?
  timeline       String?
  obstacles      String?
  desiredOutcome String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

model MentorRequest {
  id            String        @id @default(uuid())
  studentId     String
  student       User          @relation("StudentRequests", fields: [studentId], references: [id])
  mentorId      String
  mentor        User          @relation("MentorRequests", fields: [mentorId], references: [id])
  question      String
  context       String
  targetOutcome String
  timeframe     String
  status        RequestStatus @default(PENDING)
  sessions      Session[]
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
}

model Session {
  id          String        @id @default(uuid())
  requestId   String
  request     MentorRequest @relation(fields: [requestId], references: [id])
  scheduledAt DateTime
  durationMin Int           @default(60)
  status      SessionStatus @default(SCHEDULED)
  notes       String?
  outcome     Outcome?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
}

model Outcome {
  id          String   @id @default(uuid())
  sessionId   String   @unique
  session     Session  @relation(fields: [sessionId], references: [id])
  description String
  isVerified  Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Review {
  id        String   @id @default(uuid())
  authorId  String
  author    User     @relation("ReviewAuthor", fields: [authorId], references: [id])
  targetId  String
  target    User     @relation("ReviewTarget", fields: [targetId], references: [id])
  rating    Int
  comment   String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
